generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model grocery_lists {
  id          Int          @id @default(autoincrement())
  user_id     Int
  name        String       @db.VarChar(100)
  description String?      @db.Text
  created_at  DateTime     @default(now()) @db.Timestamp(0)
  updated_at  DateTime     @default(now()) @db.Timestamp(0)
  users       users        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "grocery_lists_ibfk_1")
  list_items  list_items[]

  @@index([user_id], map: "user_id")
}

model list_items {
  id              Int           @id @default(autoincrement())
  grocery_list_id Int
  product_id      Int
  quantity        Int
  notes           String?       @db.Text
  is_bought       Boolean?      @default(false)
  created_at      DateTime      @default(now()) @db.Timestamp(0)
  grocery_lists   grocery_lists @relation(fields: [grocery_list_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "list_items_ibfk_1")
  products        products      @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "list_items_ibfk_2")

  @@index([grocery_list_id], map: "grocery_list_id")
  @@index([product_id], map: "product_id")
}

model products {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100)
  category     String?      @db.VarChar(100)
  default_unit String?      @db.VarChar(50)
  created_at   DateTime     @default(now()) @db.Timestamp(0)
  list_items   list_items[]
}

model users {
  id            Int             @id @default(autoincrement())
  username      String          @db.VarChar(50)
  email         String?         @db.VarChar(100)
  display_name  String?         @db.VarChar(100)
  created_at    DateTime        @default(now()) @db.Timestamp(0)
  grocery_lists grocery_lists[]
}
