generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model grocery_lists {
  id          Int          @id @default(autoincrement())
  user_id     Int
  name        String       @db.VarChar
  description String?      @db.VarChar
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?    @default(now()) @db.Timestamp(6)
  users       users        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user")
  list_items  list_items[]
}

model list_items {
  id              Int           @id @default(autoincrement())
  grocery_list_id Int
  product_id      Int
  quantity        Int           @default(1)
  notes           String?       @db.VarChar
  is_bought       Boolean?      @default(false)
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  grocery_lists   grocery_lists @relation(fields: [grocery_list_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_list")
  products        products      @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_product")
}

model products {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar
  category     String?      @db.VarChar
  default_unit String?      @db.VarChar
  barcode      String?      @db.VarChar
  created_at   DateTime     @default(now()) @db.Timestamp(6)
  list_items   list_items[]
}

model users {
  id            Int             @id @default(autoincrement())
  email         String          @unique @db.VarChar
  password      String          @db.VarChar
  display_name  String?         @db.VarChar
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  grocery_lists grocery_lists[]
}
